{
  "name": "richie-router-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "demo",
    "docs"
  ],
  "scripts": {
    "demo:generate": "bun scripts/generate-demo-routes.ts",
    "docs:generate": "bun scripts/generate-docs-routes.ts",
    "demo:start": "bun demo/backend/main.tsx",
    "docs:start": "bun docs/backend/main.tsx",
    "dev": "bun run demo:generate && bun --hot demo/backend/main.tsx",
    "build": "bun run demo:generate && bun run docs:generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:e2e": "bun run demo:generate && bun run docs:generate && playwright test",
    "test": "bun run test:e2e && bun run typecheck"
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19",
    "zod": "^4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "esbuild": "^0.25.11",
    "typescript": "^5.9.3"
  }
}
